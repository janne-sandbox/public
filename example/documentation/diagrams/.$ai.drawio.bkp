  <!-- ================================================================
       TAB 3: REPOSITORIES
       All repository types used in the process:
       - Materials repository (raw inputs, drawings, questions)
       - Functional requirements repository (use cases, user stories)
       - Non-functional requirements / ASRs (SHARED across projects)
       - Specifications repository (combined FR+NFR, ADRs)
       - Git source-code repository (code, CI/CD, tags)
       - Documentation repository (API docs, compliance, HTML pages)
       Cylinders = persistent/versioned storage.
       Orange border = shared across multiple projects.
       ================================================================ -->
  <diagram id="YYrvf1fhsgIlSehTTfvx" name="repositories">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
