        </mxCell>
        <mxCell id="ce4" value="SQL :5432" style="endArrow=classic;html=1;rounded=0;fontSize=10;" edge="1" source="comp-backend" target="comp-postgres" parent="zone-docker">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce5" value="OAuth2/OIDC" style="endArrow=classic;html=1;rounded=0;fontSize=10;dashed=1;" edge="1" source="comp-backend" target="comp-keycloak" parent="zone-docker">
