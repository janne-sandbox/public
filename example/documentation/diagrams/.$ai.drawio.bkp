          <mxGeometry x="1010" y="220" width="200" height="80" as="geometry" />
        </mxCell>
        <!-- Device -->
        <mxCell id="comp-device" value="hello-world-device&#xa;(internal)&#xa;Rust&#xa;Alarm device simulator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="zone-docker">
          <mxGeometry x="1010" y="100" width="200" height="80" as="geometry" />
        </mxCell>
        <!-- PostgreSQL -->
        <mxCell id="comp-postgres" value="PostgreSQL&#xa;postgres:5432&#xa;Persistent data store" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="zone-docker">
          <mxGeometry x="330" y="420" width="150" height="90" as="geometry" />
        </mxCell>
        <!-- Keycloak -->
