        <mxCell id="ce7" value="AMQP :61616" style="endArrow=classic;html=1;rounded=0;fontSize=10;" edge="1" source="comp-device" target="comp-artemis" parent="zone-docker">
          <mxGeometry relative="1" as="geometry" />
