  <!-- ================================================================
       TAB 4: MILESTONES
       How the development process fits into an agile delivery lifecycle
       aligned with TOGAF ADM phases and ITIL 4 service management.
       Three rows of framework alignment (TOGAF / ITIL / Agile),
       plus a concrete hello-world sample schedule (M1-M7, 16 weeks).
       TOGAF ADM: Preliminary -> A -> B-D -> E-F -> G-H -> ADM Change
       ITIL 4:    Strategy -> Design -> Transition -> Operation
       Agile:     Sprint 0 -> Sprint 1-N -> UAT -> Go-Live -> Ops
       ================================================================ -->
  <diagram id="QikNhIm6O8TWDJN9w7vS" name="milestones">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1650" pageHeight="1100" math="0" shadow="0">
