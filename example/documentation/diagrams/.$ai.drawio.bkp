          <mxGeometry x="20" y="50" width="160" height="65" as="geometry" />
        </mxCell>
        <mxCell id="comp-grafana" value="Grafana&#xa;grafana:3001&#xa;Dashboards &amp; alerts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="zone-obs">
          <mxGeometry x="205" y="50" width="160" height="65" as="geometry" />
        </mxCell>
        <mxCell id="comp-loki" value="Loki&#xa;loki:3100&#xa;Log aggregation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="zone-obs">
          <mxGeometry x="390" y="50" width="160" height="65" as="geometry" />
        </mxCell>
        <mxCell id="comp-promtail" value="Promtail&#xa;(internal)&#xa;Log shipper to Loki" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="zone-obs">
          <mxGeometry x="575" y="50" width="160" height="65" as="geometry" />
        </mxCell>
        <mxCell id="comp-jaeger" value="Jaeger&#xa;jaeger:16686 (UI)&#xa;Distributed tracing (OTLP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="zone-obs">
          <mxGeometry x="760" y="50" width="160" height="65" as="geometry" />
        </mxCell>
        <!-- Edges inside docker zone -->
        <mxCell id="ce2" value="/ SPA" style="endArrow=classic;html=1;rounded=0;fontSize=10;" edge="1" source="comp-nginx" target="comp-frontend" parent="zone-docker">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce3" value="/api/ /ws /docs" style="endArrow=classic;html=1;rounded=0;fontSize=10;" edge="1" source="comp-nginx" target="comp-backend" parent="zone-docker">
